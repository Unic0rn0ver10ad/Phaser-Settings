{
  "name": "phaser-settings",
  "version": "0.2.0",
  "description": "Data-driven Phaser 3 settings system with schema, storage adapter, and modal UI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "docs", "AGENTS.md", "PUBLIC_API.md"],
  "scripts": {
    "build": "node scripts/inject-version.cjs && tsc",
    "postinstall": "npm run build",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "dev:playground": "npm run build && npm install --prefix apps/playground && npm run dev --prefix apps/playground",
    "build:playground": "npm run build && npm run build --prefix apps/playground",
    "test:playground": "npm run test --prefix apps/playground",
    "verify:pack": "node scripts/verify-pack.cjs"
  },
  "peerDependencies": {
    "phaser": "^3.60.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "phaser": "^3.90.0",
    "typescript": "~5.6.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Unic0rn0ver10ad/Phaser-Settings.git"
  }
}
